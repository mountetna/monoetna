  :snakemake_profile_dir: /app/spec/fixtures/v2/profiles/
  # Remote = vulcan_c4_env
  :base_dir: /app/vulcan
  :conda_env: conda-vulcan
  :ssh:
    :host: vulcan_c4_env
    :username: root
    :password: root
