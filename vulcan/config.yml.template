default: &default
  :host: vulcan_db
  :adapter: postgresql
  :encoding: unicode
  :user: developer
  :password: password
  :pool: 5
  :timeout: 5000

:development:
  # :inject_token: <your-production-token-to-use-in-development>
  :magma:
    :host: https://magma.development.local
    :runner_host: https://magma.development.local # Change this to production host to use production data and have a functional connection from a true HPC remote.
    :hmac_key: haggis
  :vulcan:
    :host: https://vulcan.development.local
    :hmac_key: haggis
  :timur:
    :host: https://timur.development.local
    :hmac_key: haggis
